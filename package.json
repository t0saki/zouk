{
  "name": "zouk",
  "version": "0.1.0",
  "description": "Local Zouk server and frontend workspace",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "build": "npm run build --workspace=web",
    "start": "node server/index.js",
    "dev": "node bin/start.js",
    "server": "node server/index.js",
    "web:dev": "npm run dev --workspace=web"
  },
  "bin": {
    "zouk": "./bin/start.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "cors": "^2.8.5"
  }
}
